# Research/backtesting only — no live trading credentials needed by default.
# Copy to .env on the Windows VPS and fill paths only (never commit .env).

# --- Safety (defaults block all live orders) ---
PAPER_ONLY=true
LIVE_TRADING=false
# Required only if LIVE_TRADING=true AND PAPER_ONLY=false:
# LIVE_TRADING_CONFIRM=I_UNDERSTAND_RISK

# --- Paths (Windows VPS) ---
DATA_DIR=data
REPORTS_DIR=data/reports
LIVE_LOG_DIR=data/live
SCALPER_CONFIG=configs/production/mnq_walkforward_optimized.yaml

# Live feed: NinjaTrader 8 ScalperL2Exporter strategy (Rithmic/sim L2 via NT8 data stream)
# See integrations/ninjatrader8/README.md and deploy/windows/CURSOR_VPS_SETUP.md
BAR_CSV_PATH=C:\Bots\futures-trend-day-l2-scalper\data\live\nt8_mnq_1m.csv
# Alias for NT8 strategy ExportPath parameter (used if BAR_CSV_PATH is empty)
NT8_EXPORT_PATH=C:\Bots\futures-trend-day-l2-scalper\data\live\nt8_mnq_1m.csv

# DEPRECATED for live paper follow — historical ETL only (scripts/convert_l2_to_bars.py)
FUTURESBOT_ARCHIVE_ROOT=C:\TradeData\StorageBox\bundles\futuresbot\archives\l2

# --- Runner ---
RUNNER_MODE=follow
POLL_SECONDS=2
LOG_LEVEL=INFO

# --- VPS / remote (Linux Hostinger — for ETL sync only, not Windows trading host) ---
# SSH host from jarvis-one/respondermade/docs/vps-audit.md
VPS_SSH_HOST=187.124.244.78
VPS_SSH_USER=root
# Identity file path on your workstation (do not store key contents here):
VPS_SSH_IDENTITY_FILE=%USERPROFILE%\.ssh\hostinger_vps

# --- Broker credentials (leave empty until live gateway is implemented) ---
# RITHMIC_USER=
# RITHMIC_PASSWORD=
# RITHMIC_SYSTEM=
# NINJATRADER_ACCOUNT=
